FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Install build-essential FIRST (includes make, g++, gcc, etc.)
RUN apt-get update && \
    apt-get install -y \
        build-essential \
        cmake \
        pkg-config \
        git \
    && apt-get clean

# Then install the rest of the dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        libopencv-dev \
        qt6-base-dev \
        libgl1-mesa-dev \
        libgtest-dev \
        libgmock-dev \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY . .

RUN mkdir -p build_tests && cd build_tests && \
    cmake .. -DCMAKE_BUILD_TYPE=Release && \
    make -j$(nproc) Image_Redactor_Tests

CMD ["./build_tests/Image_Redactor_Tests"]